# Google Apps Script Bridge URL (required)
# This is the bridge that fetches slides without exposing API keys
VITE_BRIDGE_URL=https://script.google.com/a/macros/enjoy-digital.co.uk/s/YOUR_SCRIPT_ID/exec

# Google Slides Presentation ID (required)
# Get this from the URL of your Google Slides presentation
VITE_SLIDES_PRESENTATION_ID=your_google_slides_id_here

# Access PIN (required for admin authorization)
# This PIN is used to authorize displays - only entered on admin device, NOT on TV
VITE_ACCESS_PIN=1234

# NOTE: IP-based authentication has been removed
# The app now uses Display Code Pairing instead
# - TV shows a 6-character code
# - Admin visits ?admin=true on another device
# - Enter the code + PIN to authorize the display for 30 days
